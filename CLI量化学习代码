def _compute_simple_reversal(data):
    ret = calc_returns(data)
    ranked = calc_rank(ret)
    result = {}
    for name in ranked:
        result[name] = -1 * ranked[name]
    return result


def _compute_volume_price_divergence(data):
    vol = {s["name"]: s["volume"].astype(float) for s in data}
    ret = calc_returns(data)
    d_vol = calc_delta(vol, 2)
    r_vol = calc_rank(d_vol)
    r_ret = calc_rank(ret)
    corr = calc_correlation(r_vol, r_ret, 6)
    result = {}
    for name in corr:
        result[name] = -1 * corr[name]
    return result


def _compute_vwap_open_gap(data):
    vwap = calc_vwap(data)
    vwap_mean = calc_ts_mean(vwap, 10)
    open_gap = {}
    close_gap = {}
    for stock in data:
        name = stock["name"]
        open_gap[name] = stock["open"] - np.nan_to_num(vwap_mean[name], nan=stock["open"][0])
        close_gap[name] = stock["close"] - vwap[name]
    r_open = calc_rank(open_gap)
    r_close = calc_rank(close_gap)
    result = {}
    for name in r_open:
        result[name] = r_open[name] * (-1 * np.abs(r_close[name]))
    return result


def _compute_momentum_rank(data):
    ret = calc_returns(data)
    return calc_ts_rank(ret, 5)


def _compute_risk_adjusted(data):
    ret = calc_returns(data)
    r_ret = calc_rank(ret)
    # 计算 10 日波动率
    std_ret = {}
    for name, vals in ret.items():
        n = len(vals)
        out = np.zeros(n)
        for t in range(9, n):
            out[t] = np.std(vals[t - 9:t + 1])
        std_ret[name] = out
    r_std = calc_rank(std_ret)
    result = {}
    for name in r_ret:
        result[name] = r_ret[name] / (r_std[name] + 0.1)
    return result


