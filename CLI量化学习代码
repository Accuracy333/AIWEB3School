# 因子计算引擎（AI 辅助设计，手动验证）
# ============================================================

def calc_returns(data):
    """日收益率: (close_t - close_{t-1}) / close_{t-1}"""
    result = {}
    for stock in data:
        c = stock["close"]
        ret = np.zeros_like(c)
        ret[1:] = (c[1:] - c[:-1]) / c[:-1]
        result[stock["name"]] = ret
    return result


def calc_rank(values_dict):
    """
    截面排名 rank():
    同一时间点，对所有股票的某个值从小到大排名，归一化到 [0, 1]
    """
    names = list(values_dict.keys())
    n = len(values_dict[names[0]])
    result = {name: np.zeros(n) for name in names}
    for t in range(n):
        vals = np.array([values_dict[name][t] for name in names])
        from scipy.stats import rankdata
        ranks = rankdata(vals)
        result_at_t = (ranks - 1) / (len(ranks) - 1)  # 归一化到 [0, 1]
        for i, name in enumerate(names):
            result[name][t] = result_at_t[i]
    return result


def calc_ts_rank(values_dict, window=5):
    """
    时间序列排名 ts_rank(x, d):
    对每只股票，过去 d 天的当前值在历史窗口中的排名
    """
    result = {}
    for name, vals in values_dict.items():
        n = len(vals)
        out = np.full(n, 0.5)
        for t in range(window - 1, n):
            window_vals = vals[t - window + 1:t + 1]
            rank = sum(1 for v in window_vals if v <= vals[t])
            out[t] = rank / window
        result[name] = out
    return result


def calc_delta(values_dict, period=1):
    """变化量 delta(x, d) = x_t - x_{t-d}"""
    result = {}
    for name, vals in values_dict.items():
        out = np.zeros_like(vals)
        out[period:] = vals[period:] - vals[:-period]
        result[name] = out
    return result


def calc_ts_mean(values_dict, window=5):
    """时间序列均值"""
    result = {}
    for name, vals in values_dict.items():
        n = len(vals)
        out = np.full(n, np.nan)
        for t in range(window - 1, n):
            out[t] = np.mean(vals[t - window + 1:t + 1])
        result[name] = out
    return result


def calc_correlation(x_dict, y_dict, window=6):
    """时序相关性 correlation(x, y, d)"""
    result = {}
    for name in x_dict:
        n = len(x_dict[name])
        out = np.zeros(n)
        for t in range(window - 1, n):
            xw = x_dict[name][t - window + 1:t + 1]
            yw = y_dict[name][t - window + 1:t + 1]
            if np.std(xw) > 0 and np.std(yw) > 0:
                out[t] = np.corrcoef(xw, yw)[0, 1]
        result[name] = out
    return result


def calc_vwap(data):
    """成交量加权平均价（简化版: 用 (H+L+C)/3 作为近似）"""
    result = {}
    for stock in data:
        vwap = (stock["high"] + stock["low"] + stock["close"]) / 3
        result[stock["name"]] = vwap
    return result


def calc_adv(data, window=20):
    """平均日成交量"""
    result = {}
    for stock in data:
        n = len(stock["volume"])
        out = np.zeros(n)
        for t in range(window - 1, n):
            out[t] = np.mean(stock["volume"][t - window + 1:t + 1])
        result[stock["name"]] = out
    return result


