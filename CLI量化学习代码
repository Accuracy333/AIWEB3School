    table = Table(
        title=f"{alpha_name} - 第 {day_idx + 1} 天 因子信号（截面排名）",
        box=box.SIMPLE, show_lines=True
    )
    table.add_column("排名", justify="center", width=6)
    table.add_column("股票", style="bold", width=12)
    table.add_column("因子值", justify="right", width=12)
    table.add_column("信号", justify="center", width=16)
    table.add_column("信号强度", width=20)

    n = len(vals)
    for i, (name, v) in enumerate(vals):
        # 信号方向
        if v > 0.3:
            signal = "[bold red]强烈做多[/bold red]"
        elif v > 0.1:
            signal = "[red]做多[/red]"
        elif v > -0.1:
            signal = "[dim]中性[/dim]"
        elif v > -0.3:
            signal = "[green]做空[/green]"
        else:
            signal = "[bold green]强烈做空[/bold green]"

        # 可视化信号强度
        bar_len = int(abs(v) * 30)
        if v > 0:
            bar = f"[red]{'|' * bar_len}[/]"
        else:
            bar = f"[green]{'|' * bar_len}[/]"

        table.add_row(
            str(i + 1), name, f"{v:+.4f}", signal, bar
        )

    console.print(table)
    console.print()

