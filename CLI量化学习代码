STOCK_NAMES = [
    "贵州茅台", "宁德时代", "比亚迪", "招商银行", "中国平安",
    "腾讯控股", "阿里巴巴", "美团", "京东", "拼多多",
    "中芯国际", "药明康德", "隆基绿能", "海康威视", "迈瑞医疗",
]

np.random.seed(42)
BASE_PRICES = np.array([1800, 210, 260, 35, 48, 370, 85, 130, 150, 120,
                        50, 65, 28, 32, 280], dtype=float)


def generate_data(num_days=20):
    """生成模拟 OHLCV 数据"""
    data = []
    for name, base in zip(STOCK_NAMES, BASE_PRICES):
        daily_returns = np.random.normal(0.0005, 0.025, num_days)
        daily_returns[0] = 0
        close = base * np.cumprod(1 + daily_returns)
        close = np.round(close, 2)
        opens = close * (1 + np.random.normal(0, 0.005, num_days))
        opens = np.round(opens, 2)
        highs = np.maximum(opens, close) * (1 + abs(np.random.normal(0, 0.008, num_days)))
        highs = np.round(highs, 2)
        lows = np.minimum(opens, close) * (1 - abs(np.random.normal(0, 0.008, num_days)))
        lows = np.round(np.maximum(lows, 0.01), 2)
        volume = np.random.randint(500_000, 50_000_000, num_days)
        data.append({
            "name": name,
            "close": close,
            "open": opens,
            "high": highs,
            "low": lows,
            "volume": volume,
        })
    return data


